\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"ruleset_id\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The ID of the ruleset.\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"includes_parents\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Include rulesets configured at higher levels that apply to this repository\",\n          \"type\": \"boolean\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"404\",\n        \"500\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"ruleset_id\"\n        ],\n        \"query\": [\n          \"includes_parents\"\n        ],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/update-repo-ruleset\",\n      \"method\": \"PUT\",\n      \"path\": \"/repos/{owner}/{repo}/rulesets/{ruleset_id}\",\n      \"tag\": \"repos\",\n      \"summary\": \"Update a repository ruleset\",\n      \"description\": \"Update a ruleset for a repository.\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"ruleset_id\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The ID of the ruleset.\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": true,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"200\",\n        \"404\",\n        \"422\",\n        \"500\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"ruleset_id\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": true\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/delete-repo-ruleset\",\n      \"method\": \"DELETE\",\n      \"path\": \"/repos/{owner}/{repo}/rulesets/{ruleset_id}\",\n      \"tag\": \"repos\",\n      \"summary\": \"Delete a repository ruleset\",\n      \"description\": \"Delete a ruleset for a repository.\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"ruleset_id\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The ID of the ruleset.\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"destructive\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"204\",\n        \"404\",\n        \"500\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"ruleset_id\"\n        ],\n      