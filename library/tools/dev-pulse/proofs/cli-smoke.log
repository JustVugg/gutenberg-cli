\": [\n        \"200\",\n        \"304\",\n        \"401\",\n        \"403\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [],\n        \"query\": [\n          \"per_page\",\n          \"page\"\n        ],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"users/create-ssh-signing-key-for-authenticated-user\",\n      \"method\": \"POST\",\n      \"path\": \"/user/ssh_signing_keys\",\n      \"tag\": \"users\",\n      \"summary\": \"Create a SSH signing key for the authenticated user\",\n      \"description\": \"Creates an SSH signing key for the authenticated user's GitHub account.\\n\\nOAuth app tokens and personal access tokens (classic) need the `write:ssh_signing_key` scope to use this endpoint.\",\n      \"parameters\": [],\n      \"hasRequestBody\": true,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"201\",\n        \"304\",\n        \"401\",\n        \"403\",\n        \"404\",\n        \"422\"\n      ],\n      \"inputHints\": {\n        \"path\": [],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": true\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"users/get-ssh-signing-key-for-authenticated-user\",\n      \"method\": \"GET\",\n      \"path\": \"/user/ssh_signing_keys/{ssh_signing_key_id}\",\n      \"tag\": \"users\",\n      \"summary\": \"Get an SSH signing key for the authenticated user\",\n      \"description\": \"Gets extended details for an SSH signing key.\\n\\nOAuth app tokens and personal access tokens (classic) need the `read:ssh_signing_key` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"ssh_signing_key_id\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The unique identifier of the SSH signing key.\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"304\",\n        \"401\",\n        \"403\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"ssh_signing_key_id\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"users/delete-ssh-signing-key-for-authenticated-user\",\n      \"method\": \"DELETE\",\n      \"path\": \"/user/ssh_signing_keys/{ssh_signing_key_id}\",\n      \"tag\": \"users\",\n      \"summary\": \"Delete an SSH signing key for the authenticated user\",\n      \"description\": \"Deletes an SSH signing key from the authenticated user's GitHub account.\\n\\nOAuth app tokens and personal access tokens (classic) need the `admin:ssh_signing_key` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"ssh_signing_key_id\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The unique identifier of the SSH signing key.\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"destructive\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"204\",\n        \"304\",\n        \"401\",\n        \"403\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"ssh_signing_key_id\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"activity/list-repos-starred-by-authenticated-user\",\n      \"method\": \"GET\",\n      \"path\": \"/user/starred\",\n      \"tag\": \"activity\",\n      \"summary\": \"List repositories starred by the authenticated user\",\n      \"description\": \"Lists repositories the authenticated user has starred.\\n\\nThis endpoint supports the following custom media types. F