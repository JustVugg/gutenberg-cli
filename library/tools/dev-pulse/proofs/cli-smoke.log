n          \"name\": \"key\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"304\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"key\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"credentials/revoke\",\n      \"method\": \"POST\",\n      \"path\": \"/credentials/revoke\",\n      \"tag\": \"credentials\",\n      \"summary\": \"Revoke a list of credentials\",\n      \"description\": \"Submit a list of credentials to be revoked. This endpoint is intended to revoke credentials the caller does not own and may have found exposed on GitHub.com or elsewhere. It can also be used for credentials associated with an old user account that you no longer have access to. Credential owners will be notified of the revocation.\\n\\nThis endpoint currently accepts the following credential types:\\n- Personal access tokens (classic) (`ghp_`)\\n- Fine-grained personal access tokens (`github_pat_`)\\n- OAuth app access tokens (`gho_`)\\n- User-to-server tokens from GitHub Apps (`ghu_`)\\n- Refresh tokens from GitHub Apps (`ghr_`)\\n\\n\\nRevoked credentials may impact users on GitHub Free, Pro, \u0026 Team and GitHub Enterprise Cloud, and GitHub Enterprise Cloud with Enterprise Managed Users.\\nGitHub cannot reactivate any credentials that have been revoked; new credentials will need to be generated.\\n\\nTo prevent abuse, this API is limited to only 60 unauthenticated requests per hour and a max of 1000 tokens per API request.\\n\\n\u003e [!NOTE]\\n\u003e Any authenticated requests will return a 403.\",\n      \"parameters\": [],\n      \"hasRequestBody\": true,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"202\",\n        \"422\",\n        \"500\"\n      ],\n      \"inputHints\": {\n        \"path\": [],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": true\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"emojis/get\",\n      \"method\": \"GET\",\n      \"path\": \"/emojis\",\n      \"tag\": \"emojis\",\n      \"summary\": \"Get emojis\",\n      \"description\": \"Lists all the emojis available to use on GitHub.\",\n      \"parameters\": [],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"304\"\n      ],\n      \"inputHints\": {\n        \"path\": [],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/get-actions-cache-retention-limit-for-enterprise\",\n      \"method\": \"GET\",\n      \"path\": \"/enterprises/{enterprise}/actions/cache/retention-limit\",\n      \"tag\": \"actions\",\n      \"summary\": \"Get GitHub Actions cache retention limit for an enterprise\",\n      \"description\": \"Gets GitHub Actions cache retention limit for an enterprise. All organizations and repositories under this\\nenterprise may not set a higher cache retention limit.\\n\\nOAuth tokens and personal access tokens (classic) need the `admin:enterprise` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"enterprise\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The slug version of the enterprise name.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"403\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"enterprise\"\n        ],\