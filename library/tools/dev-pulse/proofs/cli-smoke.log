nt.\\n\\nOAuth app tokens and personal access tokens (classic) need the `admin:org` scope to use this endpoint.  If the repository is private, the `repo` scope is also required.\",\n      \"parameters\": [\n        {\n          \"name\": \"org\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The organization name. The name is not case sensitive.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"org\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/generate-runner-jitconfig-for-org\",\n      \"method\": \"POST\",\n      \"path\": \"/orgs/{org}/actions/runners/generate-jitconfig\",\n      \"tag\": \"actions\",\n      \"summary\": \"Create configuration for a just-in-time runner for an organization\",\n      \"description\": \"Generates a configuration that can be passed to the runner application at startup.\\n\\nThe authenticated user must have admin access to the organization.\\n\\nOAuth tokens and personal access tokens (classic) need the`admin:org` scope to use this endpoint. If the repository is private, OAuth tokens and personal access tokens (classic) need the `repo` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"org\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The organization name. The name is not case sensitive.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": true,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"201\",\n        \"404\",\n        \"409\",\n        \"422\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n 