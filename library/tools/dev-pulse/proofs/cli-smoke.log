      \"hasRequestBody\": true,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"201\",\n        \"422\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": true\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/get-autolink\",\n      \"method\": \"GET\",\n      \"path\": \"/repos/{owner}/{repo}/autolinks/{autolink_id}\",\n      \"tag\": \"repos\",\n      \"summary\": \"Get an autolink reference of a repository\",\n      \"description\": \"This returns a single autolink reference by ID that was configured for the given repository.\\n\\nInformation about autolinks are only available to repository administrators.\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"autolink_id\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The unique identifier of the autolink.\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"autolink_id\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n   