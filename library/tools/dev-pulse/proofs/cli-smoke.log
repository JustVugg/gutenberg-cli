string\"\n        },\n        {\n          \"name\": \"type\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Limit results to repositories of the specified type.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"sort\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The property to sort the results by.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"direction\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The order to sort by. Default: `asc` when using `full_name`, otherwise `desc`.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"per_page\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The number of results per page (max 100). For more information, see \\\"[Using pagination in the REST API](https://docs.github.com/rest/using-the-rest-api/using-pagination-in-the-rest-api).\\\"\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"page\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The page number of the results to fetch. For more information, see \\\"[Using pagination in the REST API](https://docs.github.com/rest/using-the-rest-api/using-pagination-in-the-rest-api).\\\"\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"username\"\n        ],\n        \"query\": [\n          \"type\",\n          \"sort\",\n          \"direction\",\n          \"per_page\",\n          \"page\"\n        ],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"billing/get-github-billing-premium-request-usage-report-user\",\n      \"method\": \"GET\",\n      \"path\": \"/users/{username}/settings/billing/premium_request/usage\",\n      \"tag\": \"billing\",\n      \"summary\": \"Get billing premium request usage report for a user\",\n      \"description\": \"Gets a report of premium request usage for a user.\\n\\n**Note:** Only data from the past 24 months is accessible via this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"username\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The handle for the GitHub user account.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"year\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"If specified, only return results for a single year. The value of `year` is an integer with four digits representing a year. For example, `2025`. Default value is the current year.\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"month\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"If specified, only return results for a single month. The value of `month` is an integer between `1` and `12`. Default value is the current month. If no year is specified the default `year` is used.\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"day\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"If specified, only return results for a single day. The value of `day` is an integer between `1` and `31`. If no `year` or `month` is specified, the default `year` and `month` are used.\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"model\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The model name to query usage for. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"product\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The product name to query usage for. The name is not case sensitive.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"400\",\n        \"403\",\n        \"404\",\n        \"500\",\n        \"503\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"username\"\n        ],\n        \"query\": [\n          \"year\",\n          \"month\",\n          \"day\",\n          \"model\",\n          \"product\"\n        ],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"billing/get-github-billing-usage-report-user\",\n      \"method\": \"GET\",\n      \"path\": \"/users/{username}/settings/billing/usage\",\n      \"tag\": \"billing\",\n      \"summary\": \"Get billing usage report for a user\",\n      \"description\": \"Gets a report of the total usage for a user.\\n\\n**Note:** This endpoint is only available to users with access to the enhanced billing platform.\",\n      \"parameters\": [\n        {\n          \"name\": \"username\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The handle for the GitHub user account.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"year\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"If specified, only return results for a single year. The value of `year` is an integer with four digits representing a year. For example, `2025`. Default value is the current year.\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"month\",\n          \"in\": \"query\",\n          \"required\": false,\