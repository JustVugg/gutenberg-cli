nabled, disabled or paused for a repository. The authenticated user must have admin read access to the repository. For more information, see \\\"[Configuring Dependabot security updates](https://docs.github.com/articles/configuring-automated-security-fixes)\\\".\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/enable-automated-security-fixes\",\n      \"method\": \"PUT\",\n      \"path\": \"/repos/{owner}/{repo}/automated-security-fixes\",\n      \"tag\": \"repos\",\n      \"summary\": \"Enable Dependabot security updates\",\n      \"description\": \"Enables Dependabot security updates for a repository. The authenticated user must have admin access to the repository. For more information, see \\\"[Configuring Dependabot security updates](https://docs.github.com/articles/configuring-automated-security-fixes)\\\".\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"204\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/disable-automated-security-fixes\",\n      \"method\": \"DELETE\",\n      \"path\": \"/repos/{owner}/{repo}/automated-security-fixes\",\n      \"tag\": \"repos\",\n      \"summary\": \"Disable Dependabot security updates\",\n      \"description\": \"Disables Dependabot security updates for a repository. The authenticated user must have admin access to the repository. For more information, see \\\"[Configuring Dependabot security updates](https://docs.github.com/articles/configuring-automated-security-fixes)\\\".\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"destructive\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"204\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/list-branches\",\n      \"method\": \"GET\",\n      \"path\": \"/repos/{owner}/{repo}/branches\",\n      \"tag\": \"repos\",\n      \"summary\": \"List branches\",\n      \"description\": \"\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"protected\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Setting to `true` returns only branches protected by branch protections or rulesets. When set to `false`, only unprotected branches are returned. Omitting this parameter returns all branches.\",\n          \"type\": \"boolean\"\n        },\n        {\n          \"name\": \"per_page\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The number of results per page (max 100). For more information, see \\\"[Using pagination in the REST API](https://docs.github.com/rest/using-the-rest-api/using-pagination-in-the-rest-api).\\\"\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"page\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The page number of the results to fetch. For more information, see \\\"[Using pagination in the REST API](https://docs.github.com/rest/using-the-rest-api/using-pagination-in-the-rest-api).\\\"\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [\n          \"protected\",\n          \"per_page\",\n          \"page\"\n        ],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"repos/get-branch\",\n      \"method\": \"GET\",\n      \"path\": \"/repos/{owner}/{repo}/branches/{branch}\",\n      \"tag\": \"repos\",\n      \"summary\": \"Get a branch\",\n      \"description\": \"\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"branch\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the branch. Cannot contain wildcard characters. To use wildcard characters in branch names, use [the GraphQL API](https://docs.github.com/graphql).\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"301\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"branch\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n 