\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/get-repo-secret\",\n      \"method\": \"GET\",\n      \"path\": \"/repos/{owner}/{repo}/actions/secrets/{secret_name}\",\n      \"tag\": \"actions\",\n      \"summary\": \"Get a repository secret\",\n      \"description\": \"Gets a single repository secret without revealing its encrypted value.\\n\\nThe authenticated user must have collaborator access to the repository to use this endpoint.\\n\\nOAuth app tokens and personal access tokens (classic) need the `repo` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"secret_name\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the secret.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"secret_name\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/create-or-update-repo-secret\",\n      \"method\": \"PUT\",\n      \"path\": \"/repos/{owner}/{repo}/actions/secrets/{secret_name}\",\n      \"tag\": \"actions\",\n      \"summary\": \"Create or update a repository secret\",\n      \"description\": \"Creates or updates a repository secret with an encrypted value. Encrypt your secret using\\n[LibSodium](https://libsodium.gitbook.io/doc/bindings_for_other_languages). For more information, see \\\"[Encrypting secrets for the REST API](https://docs.github.com/rest/guides/encrypting-secrets-for-the-rest-api).\\\"\\n\\nAuthenticated users must have collaborator access to a repository to create, update, or read secrets.\\n\\nOAuth tokens and personal access tokens (classic) need the `repo` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"secret_name\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the secret.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": true,\n      \"risk\": \"write\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"201\",\n        \"204\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"secret_name\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": true\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/delete-repo-secret\",\n      \"method\": \"DELETE\",\n      \"path\": \"/repos/{owner}/{repo}/actions/secrets/{secret_name}\",\n      \"tag\": \"actions\",\n      \"summary\": \"Delete a repository secret\",\n      \"description\": \"Deletes a secret in a repository using the secret name.\\n\\nAuthenticated users must have collaborator access to a repository to create, update, or read secrets.\\n\\nOAuth tokens and personal access tokens (classic) need the `repo` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository without the `.git` extension. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"secret_name\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the secret.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"destructive\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"204\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\",\n          \"secret_name\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/list-repo-variables\",\n      \"method\": \"GET\",\n      \"path\": \"/repos/{owner}/{repo}/actions/variables\",\n      \"tag\": \"actions\",\n      \"summary\": \"List repository variables\",\n      \"description\": \"Lis