cess tokens for \\\"List tasks for repository\\\"**\\n\\nThis endpoint works with the following fine-grained token types:\\n\\n* [GitHub App user access tokens](https://docs.github.com/en/apps/creating-github-apps/authenticating-with-a-github-app/generating-a-user-access-token-for-a-github-app)\\n* [Fine-grained personal access tokens](https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens#creating-a-fine-grained-personal-access-token)\\n\\nThe fine-grained token must have the following permission set:\\n\\n* \\\"Agent tasks\\\" repository permissions (read)\\n\\nGitHub App installation access tokens are not supported for this endpoint.\\n\",\n      \"parameters\": [\n        {\n          \"name\": \"owner\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The account owner of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"repo\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the repository. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"per_page\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The number of results per page (max 100).\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"page\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The page number of the results to fetch.\",\n          \"type\": \"integer\"\n        },\n        {\n          \"name\": \"sort\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The field to sort results by. Can be `updated_at` or `created_at`.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"direction\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"The direction to sort results. Can be `asc` or `desc`.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"state\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Comma-separated list of task states to filter by. Can be any combination of: `queued`, `in_progress`, `completed`, `failed`, `idle`, `waiting_for_user`, `timed_out`, `cancelled`.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"is_archived\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Filter by archived status. When `true`, returns only archived tasks. When `false` or omitted, returns only non-archived tasks. Defaults to `false`.\",\n          \"type\": \"boolean\"\n        },\n        {\n          \"name\": \"since\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Only show tasks updated at or after this time (ISO 8601 timestamp)\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"creator_id\",\n          \"in\": \"query\",\n          \"required\": false,\n          \"description\": \"Filter tasks by creator user ID\",\n          \"type\": \"integer\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\",\n        \"400\",\n        \"401\",\n        \"403\",\n        \"404\",\n        \"422\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"owner\",\n          \"repo\"\n        ],\n        \"query\": [\n          \"per_page\",\n          \"page\",\n          \"sort\",\n          \"direction\",\n          \"state\",\n          \"is_archived\",\n          \"since\",\n          \"creator_id\"\n        ],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {