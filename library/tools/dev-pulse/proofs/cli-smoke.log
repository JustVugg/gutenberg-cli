rns a 204 if the given user is blocked by the given organization. Returns a 404 if the organization is not blocking the user, or if the user account has been identified as spam by GitHub.\",\n      \"parameters\": [\n        {\n          \"name\": \"org\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The organization name. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"username\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The handle for the GitHub user account.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"204\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"org\",\n          \"username\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"orgs/block-user\",\n      \"method\": \"PUT\",\n      \"path\": \"/orgs/{org}/blocks/{username}\",\n      \"tag\": \"orgs\",\n      \"summary\": \"Block a user from an organization\",\n      \"description\": \"Blocks the given user on behalf of the specified organization and returns a 204. If the organization cannot block the given user a 422 is returned.\",\n      \"parameters\": [\n        {\n          \"name\": \"org\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The organization name. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"username\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The handle for the GitHub user account.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"write\",\