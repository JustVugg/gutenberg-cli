dy\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/get-org-secret\",\n      \"method\": \"GET\",\n      \"path\": \"/orgs/{org}/actions/secrets/{secret_name}\",\n      \"tag\": \"actions\",\n      \"summary\": \"Get an organization secret\",\n      \"description\": \"Gets a single organization secret without revealing its encrypted value.\\n\\nThe authenticated user must have collaborator access to a repository to create, update, or read secrets\\n\\nOAuth tokens and personal access tokens (classic) need the`admin:org` scope to use this endpoint. If the repository is private, OAuth tokens and personal access tokens (classic) need the `repo` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"org\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The organization name. The name is not case sensitive.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"secret_name\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the secret.\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"read\",\n      \"cacheable\": true,\n      \"responseCodes\": [\n        \"200\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"org\",\n          \"secret_name\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"actions/create-or-update-org-secret\",\n      \"method\": \"PUT\",\n      \"path\": \"/orgs/{org}/actions/secrets/{secret_name}\",\n      \"tag\": \"actions\",\n      \"summary\": \"Create or update an organization secret\",\n      \"description\": \"Creates or updates an organization secret with an encrypted value. Encrypt your secret using\\n[LibSodium](https://libsodium.gitbook.io/doc/bindings_for_other_langua