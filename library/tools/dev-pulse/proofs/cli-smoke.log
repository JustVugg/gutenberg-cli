: false,\n      \"responseCodes\": [\n        \"201\",\n        \"400\",\n        \"403\",\n        \"422\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"enterprise\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": true\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"oidc/delete-oidc-custom-property-inclusion-for-enterprise\",\n      \"method\": \"DELETE\",\n      \"path\": \"/enterprises/{enterprise}/actions/oidc/customization/properties/repo/{custom_property_name}\",\n      \"tag\": \"oidc\",\n      \"summary\": \"Delete an OIDC custom property inclusion for an enterprise\",\n      \"description\": \"Removes a repository custom property from being included in the OIDC token for repository actions in an enterprise.\\n\\nOAuth app tokens and personal access tokens (classic) need the `admin:enterprise` scope to use this endpoint.\",\n      \"parameters\": [\n        {\n          \"name\": \"enterprise\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The slug version of the enterprise name.\",\n          \"type\": \"string\"\n        },\n        {\n          \"name\": \"custom_property_name\",\n          \"in\": \"path\",\n          \"required\": true,\n          \"description\": \"The name of the custom property to remove from OIDC token inclusion\",\n          \"type\": \"string\"\n        }\n      ],\n      \"hasRequestBody\": false,\n      \"risk\": \"destructive\",\n      \"cacheable\": false,\n      \"responseCodes\": [\n        \"204\",\n        \"400\",\n        \"403\",\n        \"404\"\n      ],\n      \"inputHints\": {\n        \"path\": [\n          \"enterprise\",\n          \"custom_property_name\"\n        ],\n        \"query\": [],\n        \"headers\": [],\n        \"body\": false\n      },\n      \"graphql\": null\n    },\n    {\n      \"id\": \"code-security/get-configurations-for-enterprise\",\n      \"method\": \"GET\",\n      \"p